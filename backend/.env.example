# MongoDB connection string
# Local:   mongodb://localhost:27017/fsad_taskboard
# Atlas:   mongodb+srv://<user>:<password>@cluster.mongodb.net/fsad_taskboard
MONGO_URI=mongodb://localhost:27017/fsad_taskboard

# Secret key for JWT signing — use a long random string in production
JWT_SECRET=change_this_to_a_long_random_secret_before_deploying

# Token expiry (e.g. 7d, 1h)
JWT_EXPIRES_IN=7d

# Port the server listens on
PORT=5000

# Allowed frontend origin for CORS
CORS_ORIGIN=http://localhost:5173
